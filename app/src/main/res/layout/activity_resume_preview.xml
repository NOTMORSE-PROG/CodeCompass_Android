<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_back"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/colorTextPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-bold"
            android:text="@string/resume_preview"
            android:textColor="@color/colorTextPrimary"
            android:textSize="17sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/resume_export_pdf"
            android:textColor="@color/colorTextPrimary"
            android:textSize="12sp"
            app:backgroundTint="@color/colorPrimary"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- WebView -->
    <WebView
        android:id="@+id/wvPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom bar: template + color -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemplate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/resume_change_template"
            android:textColor="@color/colorTextPrimary"
            app:backgroundTint="@color/colorDivider"
            style="@style/Widget.MaterialComponents.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/resume_change_color"
            android:textColor="@color/colorTextPrimary"
            app:backgroundTint="@color/colorDivider"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</LinearLayout>

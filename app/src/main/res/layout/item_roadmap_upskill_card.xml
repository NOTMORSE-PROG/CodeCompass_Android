<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/colorWarningBackground"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvUpskillHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/upskill_card_title"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textColor="#B45309"
            android:layout_marginBottom="8dp" />

        <!-- Info box -->
        <LinearLayout
            android:id="@+id/layoutUpskillInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_upskill_info_box">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_warning_title"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#B45309"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_warning_body"
                android:textSize="11sp"
                android:textColor="#B45309"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_limit"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B45309" />
        </LinearLayout>

        <!-- Plan summary (shown when summary is non-empty) -->
        <TextView
            android:id="@+id/tvUpskillPlan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/colorTextPrimary"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <!-- Success state (GONE by default) -->
        <LinearLayout
            android:id="@+id/layoutUpskillApplied"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_applied"
                android:textSize="12sp"
                android:textColor="@color/colorSuccess"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_applied_limit"
                android:textSize="11sp"
                android:textColor="#B45309"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/btnUpskillGotIt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/roadmap_action_got_it"
                android:textSize="12sp"
                android:textColor="@color/colorTextSecondary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_btn_outline_gray" />
        </LinearLayout>

        <!-- Buttons (visible by default) -->
        <LinearLayout
            android:id="@+id/layoutUpskillButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpskillConfirm"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/upskill_card_confirm"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="6dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <TextView
                android:id="@+id/btnUpskillDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upskill_card_cancel"
                android:textSize="12sp"
                android:textColor="@color/colorTextSecondary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_btn_outline_gray"
                android:gravity="center"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

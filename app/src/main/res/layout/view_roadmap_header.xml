<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvRoadmapTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Roadmap"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvRoadmapStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/roadmap_status_active"
                android:textSize="11sp"
                android:textColor="@color/colorSuccess"
                android:textStyle="bold"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/colorSuccessBackground"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp" />

        </LinearLayout>

        <!-- Career path subtitle -->
        <TextView
            android:id="@+id/tvCareerPath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressRoadmap"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progressDrawable="@drawable/bg_progress_bar_yellow"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="8dp" />

        <!-- Percent text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvCompletionPct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" complete"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary" />

        </LinearLayout>

        <!-- Stats row: nodes done · hours left · streak -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvNodesDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0 nodes"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary" />

            <TextView
                android:id="@+id/tvHoursLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~0h left"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary" />

            <TextView
                android:id="@+id/tvStreakSeparator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvStreakStat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 0"
                android:textSize="13sp"
                android:textColor="@color/colorStreak"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

# Normalize line endings to LF on check-in (ensures CI scripts work on Linux runners)
* text=auto eol=lf

# Force shell scripts to always use LF
gradlew text eol=lf

# Treat binary files as binary (no line-ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.keystore binary
*.jks binary
*.apk binary
*.aab binary
